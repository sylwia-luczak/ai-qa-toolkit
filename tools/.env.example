# Environment variables required by the tools in this directory.
# Copy this file to .env and fill in your values.
# NEVER commit your actual .env file to git.

# Jira Personal Access Token
# Generate at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_PAT=your_jira_pat_here

# Jira base URL (no trailing slash)
JIRA_BASE_URL=https://your-org.atlassian.net

# Confluence Personal Access Token (can be the same PAT as Jira if using Atlassian Cloud)
CONFLUENCE_PAT=your_confluence_pat_here

# Confluence base URL (no trailing slash)
CONFLUENCE_BASE_URL=https://your-org.atlassian.net/wiki
